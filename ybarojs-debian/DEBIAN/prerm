#!/bin/sh
set -e

# prerm: Runs before package files are removed.
# Removes the installed config files so dpkg does not leave orphaned files
# that would block postrm from restoring the originals cleanly.

remove_dir() {
    local dir="$1"

    if [ ! -d "$dir" ]; then
        return 0
    fi

    for f in "$dir"/*; do
        [ -e "$f" ] || continue          # skip if glob found nothing
        [ -f "$f" ] || continue          # only regular files

        filename="$(basename "$f")"

        # Only remove files that are NOT backups — leave .backup files for postrm to restore
        case "$filename" in
            *.backup) continue ;;
        esac

        echo "prerm: removing $f"
        rm -f "$f"
    done
}

case "$1" in
    remove|upgrade|deconfigure)
        remove_dir /etc/sway
        remove_dir /etc/xdg/waybar
        remove_dir /etc/xdg/tofi
        remove_dir /etc/greetd
        
        # Remove ybarojs-prompt.sh sourcing from /etc/bash.bashrc
        if [ -f /etc/bash.bashrc ]; then
            BASHRC_LINE='[ -f /etc/profile.d/ybarojs-prompt.sh ] && . /etc/profile.d/ybarojs-prompt.sh'
            if grep -qF "$BASHRC_LINE" /etc/bash.bashrc; then
                echo "prerm: Removing ybarojs-prompt.sh sourcing from /etc/bash.bashrc..."
                # Remove the line and the comment above it
                sed -i '/# Source ybarojs-debian prompt configuration/d' /etc/bash.bashrc
                sed -i "/\[ -f \/etc\/profile.d\/ybarojs-prompt.sh \] && . \/etc\/profile.d\/ybarojs-prompt.sh/d" /etc/bash.bashrc
                echo "prerm: /etc/bash.bashrc cleaned up."
            fi
        fi
        ;;
esac

exit 0
