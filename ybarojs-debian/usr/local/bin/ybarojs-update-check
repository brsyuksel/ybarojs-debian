#!/bin/sh
# ybarojs-update-check - Check for firmware and package updates
# Output format for waybar: UPD <total_count>
# Tooltip format: firmware: X, packages: Y

CACHE_FILE="/tmp/ybarojs-update-check.cache"
CACHE_TTL=300  # 5 minutes cache

# Check if cache is valid
if [ -f "$CACHE_FILE" ]; then
    CACHE_MTIME=$(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0)
    CURRENT_TIME=$(date +%s)
    CACHE_AGE=$((CURRENT_TIME - CACHE_MTIME))
    if [ "$CACHE_AGE" -lt "$CACHE_TTL" ]; then
        cat "$CACHE_FILE"
        exit 0
    fi
fi

# Check firmware updates (with timeout to prevent hangs on VMs)
FW_COUNT=0
if command -v fwupdmgr >/dev/null 2>&1; then
    FW_OUT=$(timeout 5 fwupdmgr get-updates 2>/dev/null)
    if [ -n "$FW_OUT" ]; then
        FW_COUNT=$(echo "$FW_OUT" | grep -c "^│" 2>/dev/null)
    fi
fi

# Check package updates
PKG_COUNT=0
if command -v apt >/dev/null 2>&1; then
    PKG_OUT=$(apt list --upgradable 2>/dev/null)
    if [ -n "$PKG_OUT" ]; then
        PKG_COUNT=$(echo "$PKG_OUT" | grep -c "upgradable" 2>/dev/null)
    fi
fi

# Ensure counts are valid numbers (default to 0 if not)
FW_COUNT=${FW_COUNT:-0}
PKG_COUNT=${PKG_COUNT:-0}

TOTAL=$((FW_COUNT + PKG_COUNT))

# Output for waybar (JSON) - just the number, "UPD" prefix is in waybar config
OUTPUT="{\"text\": \"$TOTAL\", \"tooltip\": \"firmware: $FW_COUNT, packages: $PKG_COUNT\", \"class\": \"update-reminder\"}"

# Cache the output
echo "$OUTPUT" > "$CACHE_FILE"

# Output to stdout
echo "$OUTPUT"
