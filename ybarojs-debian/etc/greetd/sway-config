# Make wlgreet floating and centered
for_window [app_id="wlgreet"] floating enable, move position center, resize set 800 350, border pixel 2

# Disable default sway bindings that might interfere
floating_modifier Mod4

exec "/usr/sbin/wlgreet; swaymsg exit"

bindsym Mod4+shift+e exec swaynag \
	-t warning \
	-m 'What do you want to do?' \
	-b 'Poweroff' 'systemctl poweroff -i' \
	-b 'Reboot' 'systemctl reboot -i'

output * bg /usr/share/backgrounds/ybarojs-debian/wallpaper.jpg fill

exec waybar

include /etc/sway/config.d/*
include /etc/greetd/sway-config.d/*
